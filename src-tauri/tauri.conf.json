{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Oh My LinuxDo",
  "version": "0.1.0",
  "identifier": "do.linux.macos",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run vite:dev",
    "beforeBuildCommand": "npm run vite:build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Oh My LinuxDo",
        "width": 1180,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["discourse"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYwMUE5ODdCRDg0REQzNkUKUldSdTAwM1llNWdhOEtJbWljaitrdkN4LzFVZ2NWNTJWTitacUw2L0VzaEkwZDNEa3JZMUtpc1EK",
      "endpoints": [
        "https://github.com/fzlzjerry/linuxdo-macos/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
